{
    "version": 2,
    "builds": [
        {
            "src": "Guia_Audiovisual/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "includeFiles": [
                    "staticfiles/**",
                    "guia/templates/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "Guia_Audiovisual/wsgi.py"
        }
    ]
}
